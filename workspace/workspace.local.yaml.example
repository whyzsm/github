# Copy this file to workspace.local.yaml on each computer, then adjust paths.
# workspace.local.yaml is ignored by git because these paths are machine-specific.
#
# Default when omitted:
#   memoryRoot: workspace/memory
#
# Recommended Obsidian setup:
#   memoryRoot: /absolute/path/to/ObsidianVault/88-学习/xiaobai/10-项目记忆/xbaiProjectCode
#
# Optional explicit Obsidian roots. These are useful when the learning root
# contains extra path segments such as 88-学习/xiaobai.
#   memoryVaultRoot: /absolute/path/to/ObsidianVault
#   memoryLearningRootName: 88-学习/xiaobai
memoryRoot: memory
